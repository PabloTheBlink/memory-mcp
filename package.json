{
  "name": "memory-mcp",
  "version": "1.0.0",
  "description": "Associative memory MCP server with weighted knowledge graph",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx --quiet src/index.ts",
    "review": "tsx src/review-server.ts",
    "maintenance": "node dist/maintenance.js",
    "maintenance:force": "node dist/maintenance.js --force",
    "test": "vitest run",
    "migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.4.2",
    "mysql2": "^3.22.3",
    "uuid": "^11.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mysql": "^2.15.27",
    "@types/node": "^22.19.18",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
